# IBM watsonx.ai Configuration
# Get your API key from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_api_key_here

# Get your project ID from watsonx.ai project settings
WATSONX_PROJECT_ID=your_project_id_here

# Region where your watsonx.ai instance is deployed
# Options: us-south, eu-gb, eu-de, jp-tok, etc.
WATSONX_REGION=us-south

# Model to use for generation
# Options: ibm/granite-13b-chat-v2, meta-llama/llama-2-70b-chat, etc.
WATSONX_MODEL=ibm/granite-13b-chat-v2

# Optional: Advanced Configuration
# Maximum tokens for AI responses
WATSONX_MAX_TOKENS=2000

# Temperature for AI generation (0.0 - 1.0)
# Lower = more focused, Higher = more creative
WATSONX_TEMPERATURE=0.4

# Maximum number of questions to ask user
MAX_QUESTIONS=10

# Question depth level: basic, detailed, comprehensive
QUESTION_DEPTH=detailed

# Default output file path
DEFAULT_OUTPUT_PATH=specification.md

# Enable verbose logging (true/false)
VERBOSE=false

# Enable debug mode (true/false)
DEBUG=false